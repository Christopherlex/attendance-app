# Copy this file to .env and fill in the values

# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Flask secret key — use a long random string
SECRET_KEY=change-me-to-a-long-random-string-in-production

# One-time setup token to create tables via /setup?token=...
SETUP_TOKEN=pick-a-secret-token
